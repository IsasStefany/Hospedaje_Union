    private JButton crearBtn(String texto, Color bg) {
        JButton btn = new JButton(texto);
        btn.setBackground(bg);
        btn.setForeground(Color.WHITE);
        btn.setFocusPainted(false);
        btn.setBorderPainted(false);
        return btn;
    }

    private void cargarDatos() {
        modelo.setRowCount(0);
        habitaciones = habitacionDAO.listarTodas();
        for (Habitacion h : habitaciones) {
            modelo.addRow(new Object[]{
                    h.getNumero(), h.getPiso(), h.getTipoLabel(), h.getDescripcion(),
                    "S/ " + h.getPrecioNoche(),
                    h.getPrecioRebaja() != null ? "S/ " + h.getPrecioRebaja() : "-",
                    h.getDiasMinRebaja() + "+ dias",
                    h.isTieneBanioPropio() ? "Si" : "No",
                    h.getEstado(),
                    h.isEsCuartoEspecial() ? "Si" : "No"
            });
        }
    }

    private void abrirFormulario(Habitacion habExistente) {
        boolean esNueva = habExistente == null;
        JDialog dlg = new JDialog(SwingUtilities.getWindowAncestor(this),
                esNueva ? "Agregar habitacion" : "Editar habitacion",
                Dialog.ModalityType.APPLICATION_MODAL);
        dlg.setSize(460, 480);
        dlg.setLocationRelativeTo(this);

        JPanel panel = new JPanel(new GridLayout(0, 2, 10, 8));
        panel.setBorder(new EmptyBorder(20, 24, 20, 24));

        JTextField txtNumero  = new JTextField(esNueva ? "" : habExistente.getNumero());
        JSpinner spnPiso = new JSpinner(new SpinnerNumberModel(esNueva ? 2 : habExistente.getPiso(), 1, 10, 1));
        String[] tipos = {"SIMPLE","SIMPLE_2P","MATRIMONIAL","DOBLE","INDIVIDUAL"};
        JComboBox<String> cboTipo = new JComboBox<>(tipos);
        if (!esNueva) cboTipo.setSelectedItem(habExistente.getTipo());
        JTextField txtDesc    = new JTextField(esNueva ? "" : habExistente.getDescripcion());
        JTextField txtPrecio  = new JTextField(esNueva ? "" : habExistente.getPrecioNoche().toPlainString());
        JTextField txtCama1   = new JTextField(esNueva ? "" :
                (habExistente.getPrecioCama1() != null ? habExistente.getPrecioCama1().toPlainString() : ""));
        JTextField txtRebaja  = new JTextField(esNueva ? "5" :
                (habExistente.getPrecioRebaja() != null ? habExistente.getPrecioRebaja().toPlainString() : "5"));
        JSpinner spnDias = new JSpinner(new SpinnerNumberModel(esNueva ? 2 : habExistente.getDiasMinRebaja(), 1, 30, 1));
        JCheckBox chkBanio   = new JCheckBox("", !esNueva && habExistente.isTieneBanioPropio());
        JCheckBox chkEsp     = new JCheckBox("", !esNueva && habExistente.isEsCuartoEspecial());

        panel.add(new JLabel("N de habitación:")); panel.add(txtNumero);
        panel.add(new JLabel("Piso:"));            panel.add(spnPiso);
        panel.add(new JLabel("Tipo:"));            panel.add(cboTipo);
        panel.add(new JLabel("Descripción:"));     panel.add(txtDesc);
        panel.add(new JLabel("Precio/noche S/:"));  panel.add(txtPrecio);
        panel.add(new JLabel("Precio 1 cama S/:")); panel.add(txtCama1);
        panel.add(new JLabel("Rebaja S/ por noche:")); panel.add(txtRebaja);
        panel.add(new JLabel("Dias minimos rebaja:")); panel.add(spnDias);
        panel.add(new JLabel("Baño propio:"));    panel.add(chkBanio);
        panel.add(new JLabel("Cuarto especial:")); panel.add(chkEsp);

        JButton btnGuardar = crearBtn(esNueva ? "Agregar" : "Actualizar", new Color(26,26,46));
        btnGuardar.addActionListener(e -> {
            try {
                Habitacion h = esNueva ? new Habitacion() : habExistente;
                h.setNumero(txtNumero.getText().trim());
                h.setPiso((int) spnPiso.getValue());
                h.setTipo((String) cboTipo.getSelectedItem());
                h.setDescripcion(txtDesc.getText().trim());
                h.setPrecioNoche(new BigDecimal(txtPrecio.getText().trim()));
                String pc = txtCama1.getText().trim();
                h.setPrecioCama1(pc.isEmpty() ? null : new BigDecimal(pc));
                String reb = txtRebaja.getText().trim();
                h.setPrecioRebaja(reb.isEmpty() ? null : new BigDecimal(reb));
                h.setDiasMinRebaja((int) spnDias.getValue());
                h.setTieneBanioPropio(chkBanio.isSelected());
                h.setEsCuartoEspecial(chkEsp.isSelected());

                boolean ok = esNueva ? habitacionDAO.insertar(h) : habitacionDAO.actualizar(h);
                if (ok) { JOptionPane.showMessageDialog(dlg, esNueva ? "Habitacion agregada." : "Habitacion actualizada."); cargarDatos(); dlg.dispose(); }
                else JOptionPane.showMessageDialog(dlg, "Error al guardar.", "Error", JOptionPane.ERROR_MESSAGE);
            } catch (NumberFormatException ex) {
                JOptionPane.showMessageDialog(dlg, "Verifica que los precios sean numeros validos.", "Datos invalidos", JOptionPane.WARNING_MESSAGE);
            }
        });

        JPanel bottom = new JPanel(new FlowLayout(FlowLayout.RIGHT));
        JButton btnCancelar = new JButton("Cancelar");
        btnCancelar.addActionListener(e -> dlg.dispose());
        bottom.add(btnCancelar); bottom.add(btnGuardar);
        dlg.setLayout(new BorderLayout());
        dlg.add(new JScrollPane(panel), BorderLayout.CENTER);
        dlg.add(bottom, BorderLayout.SOUTH);
        dlg.setVisible(true);
    }

    private void eliminar() {
        int fila = tabla.getSelectedRow();
        if (fila < 0) { avisar("Selecciona una habitacion."); return; }
        Habitacion h = habitaciones.get(fila);
        if (h.isOcupado()) { JOptionPane.showMessageDialog(this, "No puedes eliminar una habitacion ocupada.", "Ocupada", JOptionPane.WARNING_MESSAGE); return; }
        int conf = JOptionPane.showConfirmDialog(this,
                "Eliminar habitacion " + h.getNumero() + "?",
                "Confirmar", JOptionPane.YES_NO_OPTION, JOptionPane.WARNING_MESSAGE);
        if (conf == JOptionPane.YES_OPTION) {
            if (habitacionDAO.eliminar(h.getId())) { cargarDatos(); JOptionPane.showMessageDialog(this, "Habitacion eliminada."); }
            else JOptionPane.showMessageDialog(this, "Error al eliminar.", "Error", JOptionPane.ERROR_MESSAGE);
        }
    }

    private void cambiarEstado(String nuevoEstado) {
        int fila = tabla.getSelectedRow();
        if (fila < 0) { avisar("Selecciona una habitacion."); return; }
        Habitacion h = habitaciones.get(fila);
        if ("OCUPADO".equals(h.getEstado())) { JOptionPane.showMessageDialog(this, "No puedes cambiar el estado de una habitacion ocupada.", "Ocupada", JOptionPane.WARNING_MESSAGE); return; }
        if (habitacionDAO.actualizarEstado(h.getId(), nuevoEstado)) cargarDatos();
    }

    private void avisar(String msg) { JOptionPane.showMessageDialog(this, msg, "Atencion", JOptionPane.WARNING_MESSAGE); }
}  



